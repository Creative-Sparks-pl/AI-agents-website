---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopAppBar from '../../components/sections/TopAppBar.astro';
import Footer from '../../components/sections/Footer.astro';
import KBHero from '../../components/sections/kb/KBHero.astro';
import KBPageTypes from '../../components/sections/kb/KBPageTypes.astro';
import KBFrameworks from '../../components/sections/kb/KBFrameworks.astro';
import KBPatterns from '../../components/sections/kb/KBPatterns.astro';
import KBSources from '../../components/sections/kb/KBSources.astro';
---

<BaseLayout
  title="Baza Wiedzy — 92 pliki, 16 typów stron, 13 frameworków | UX Design Agent"
  description="Pełna baza wiedzy UX wbudowana w agenta. 16 typów stron, 13 frameworków decyzyjnych, 100+ wzorców sekcji. Każda rekomendacja oparta na sprawdzonych źródłach."
>
  <TopAppBar
    navLinks={[
      { label: 'Typy stron', href: '#typy-stron' },
      { label: 'Frameworki', href: '#frameworki' },
      { label: 'Wzorce', href: '#wzorce' },
      { label: 'Źródła', href: '#zrodla' },
    ]}
    ctaLabel="Wróć na stronę główną"
    ctaHref=/ux-designer
  />
  <main>
    <KBHero />
    <KBPageTypes />
    <KBFrameworks />
    <KBPatterns />
    <KBSources />
  </main>
  <Footer />
</BaseLayout>
