---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Agent AI z bazą wiedzy UX. Sprawdzony proces od briefu do wireframe\'u. 92 pliki wiedzy, 16 typów stron, 14 obszarów. Jednorazowy zakup.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#010DFF" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=Noto+Sans+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "UX Design Agent",
        "description": "Agent AI z bazą wiedzy UX. Sprawdzony proces od briefu do wireframe'u. 92 pliki wiedzy, 16 typów stron, 14 obszarów. Jednorazowy zakup.",
        "applicationCategory": "DesignApplication",
        "operatingSystem": "Web",
        "offers": [
          {
            "@type": "Offer",
            "name": "Solo",
            "price": "799",
            "priceCurrency": "PLN",
            "description": "1 użytkownik"
          },
          {
            "@type": "Offer",
            "name": "Studio",
            "price": "1499",
            "priceCurrency": "PLN",
            "description": "Do 5 użytkowników"
          },
          {
            "@type": "Offer",
            "name": "Agencja",
            "price": "2999",
            "priceCurrency": "PLN",
            "description": "Bez limitu użytkowników"
          }
        ],
        "author": {
          "@type": "Person",
          "name": "Tomasz Maciąg",
          "jobTitle": "Founder",
          "worksFor": {
            "@type": "Organization",
            "name": "Fuse Collective"
          }
        }
      }
    </script>
  </head>
  <body class="bg-background text-foreground">
    <slot />
  </body>
</html>
