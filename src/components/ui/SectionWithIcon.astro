---
import type { HTMLAttributes } from 'astro/types';
import type { ImageMetadata } from 'astro';

interface Props extends HTMLAttributes<'div'> {
  icon?: ImageMetadata;
  layout?: 'stacked' | 'side-by-side';
  class?: string;
}

const {
  icon,
  layout = 'stacked',
  class: className,
  ...rest
} = Astro.props;
---

<div class:list={[className]} {...rest}>
  {layout === 'side-by-side' ? (
    <div class="flex flex-col lg:grid lg:grid-cols-12 gap-8 lg:gap-12">
      <div class="lg:col-span-5 lg:sticky lg:top-24 self-start">
        <div class="flex items-start gap-6">
          {icon && (
            <img
              src={icon.src}
              alt=""
              aria-hidden="true"
              class="hidden lg:block w-24 h-24 shrink-0"
            />
          )}
          <div class="flex-1 min-w-0">
            <slot name="header" />
          </div>
        </div>
      </div>
      <div class="lg:col-span-7">
        <slot />
      </div>
    </div>
  ) : (
    <>
      <div class="flex items-center gap-8 lg:gap-16 mb-8 md:mb-10">
        {icon && (
          <img
            src={icon.src}
            alt=""
            aria-hidden="true"
            class="hidden lg:block w-32 h-32 shrink-0"
          />
        )}
        <div class="flex-1 min-w-0 flex flex-col items-start">
          <slot name="header" />
        </div>
      </div>
      <div class:list={[icon && 'lg:pl-[192px]']}>
        <slot />
      </div>
    </>
  )}
</div>
