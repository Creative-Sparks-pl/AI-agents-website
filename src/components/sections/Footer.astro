---
import Logo from '../../assets/logo.svg?raw';
---

<footer class="py-12 bg-white border-t border-border/20">
  <div class="max-w-screen-2xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-8">
    <a href=/ux-designer class="text-primary block h-6 [&>svg]:h-full [&>svg]:w-auto" aria-label="Creative Sparks">
      <Fragment set:html={Logo} />
    </a>
    <div class="flex flex-wrap gap-x-10 gap-y-3 text-sm font-label">
      <a href={`$/ux-designer/polityka-prywatnosci`} class="text-muted hover:text-primary transition-colors">Polityka prywatności</a>
      <a href={`$/ux-designer/regulamin`} class="text-muted hover:text-primary transition-colors">Regulamin sprzedaży</a>
      <a href={`$/ux-designer/changelog`} class="text-muted hover:text-primary transition-colors">Changelog</a>
      <a href="mailto:tomasz@creativesparks.pl?subject=Pytanie%20w%20sprawie%20agenta" class="text-muted hover:text-primary transition-colors">Kontakt</a>
