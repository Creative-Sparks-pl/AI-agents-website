  {
    name: 'Media',
    badge: 'Treści',
    description: 'Wydawcy, blogi, magazyny. Czytelność i monetyzacja treści.',
    archetypes: [
      { name: 'News Portal', sub: 'Aktualności z szybkim cyklem publikacji.' },
      { name: 'Niche Blog', sub: 'Specjalistyczny blog z głębokim contentem.' },
      { name: 'Digital Magazine', sub: 'Magazyn z wizualnym storytellingiem.' },
    ],
    patterns: [
      { name: 'Article Grid', sub: 'Siatka artykułów z kategoriami i tagami.' },
      { name: 'Newsletter CTA', sub: 'Zachęta do subskrypcji z lead magnetem.' },
      { name: 'Category Navigation', sub: 'Nawigacja po tematach i seriach.' },
    ],
    discovery: [
      { name: 'Content Strategy', sub: 'Jakie treści przyciągają i konwertują.' },
      { name: 'Audience Segmentation', sub: 'Podział czytelników na segmenty.' },
      { name: 'Monetization Model', sub: 'Reklamy, paywall, sponsoring.' },
    ],
  },
  {
    name: 'Event',
    badge: 'Wydarzenia',
    description: 'Konferencje, webinary, wydarzenia. Rejestracja i agenda.',
    archetypes: [
      { name: 'Conference', sub: 'Wielodniowe wydarzenie z wieloma ścieżkami.' },
      { name: 'Webinar Series', sub: 'Cykl prezentacji online.' },
      { name: 'Workshop Event', sub: 'Warsztat z ograniczoną liczbą miejsc.' },
    ],
    patterns: [
      { name: 'Speaker Grid', sub: 'Prezentacja prelegentów z bio.' },
      { name: 'Agenda Timeline', sub: 'Plan dnia z podziałem na ścieżki.' },
      { name: 'Ticket Tiers', sub: 'Bilety z różnymi poziomami dostępu.' },
