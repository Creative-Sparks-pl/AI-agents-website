      { name: 'Foundation', sub: 'Fundacja z programami grantowymi.' },
      { name: 'Social Enterprise', sub: 'Biznes z misją społeczną.' },
    ],
    patterns: [
      { name: 'Impact Stats', sub: 'Metryki wpływu i osiągnięć.' },
      { name: 'Donation CTA', sub: 'Formularz darowizn z kwotami.' },
      { name: 'Beneficiary Stories', sub: 'Historie osób, którym pomożono.' },
    ],
    discovery: [
      { name: 'Donor Persona', sub: 'Kim jest typowy darczyńca.' },
      { name: 'Impact Measurement', sub: 'Jak mierzyć i komunikować wpływ.' },
      { name: 'Trust Building', sub: 'Transparentność i rozliczalność.' },
    ],
  },
  {
    name: 'Enterprise',
    badge: 'Korporacje',
    description: 'Narzędzia korporacyjne. Długi cykl sprzedaży, wielu decydentów.',
    archetypes: [
      { name: 'Enterprise SaaS', sub: 'Oprogramowanie dla dużych organizacji.' },
      { name: 'Platform', sub: 'Platforma integrująca wiele narzędzi.' },
      { name: 'Infrastructure', sub: 'Infrastruktura techniczna (cloud, hosting).' },
    ],
    patterns: [
      { name: 'Security & Compliance', sub: 'Certyfikaty, audyty, polityki.' },
      { name: 'ROI Calculator', sub: 'Kalkulator zwrotu z inwestycji.' },
      { name: 'Customer Logos Grid', sub: 'Loga klientów enterprise.' },
    ],
    discovery: [
      { name: 'Buying Committee Mapping', sub: 'Kto podejmuje decyzje zakupowe.' },
      { name: 'Integration Requirements', sub: 'Z czym musi się integrować.' },
      { name: 'Security Concerns', sub: 'Wymagania bezpieczeństwa i compliance.' },
