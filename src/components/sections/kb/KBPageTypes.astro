      { name: 'API Docs', sub: 'Dokumentacja API z przykładami kodu.' },
      { name: 'Knowledge Base', sub: 'Baza wiedzy z artykułami i FAQ.' },
      { name: 'Help Center', sub: 'Centrum pomocy z przewodnikami.' },
