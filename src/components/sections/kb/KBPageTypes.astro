    ],
    discovery: [
      { name: 'User Task Analysis', sub: 'Jakie zadania realizują czytelnicy.' },
      { name: 'Content Architecture', sub: 'Struktura i taksonomia treści.' },
      { name: 'Search Patterns', sub: 'Czego szukają i jak formułują zapytania.' },
    ],
  },
  {
    name: 'Service Utility',
    badge: 'Narzędzia',
    description: 'Narzędzia online, kalkulatory, generatory. Natychmiastowa wartość.',
    archetypes: [
