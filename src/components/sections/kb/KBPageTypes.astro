---

<section class="py-20 md:py-28 bg-surface-primary" id="typy-stron">
  <div class="max-w-screen-2xl mx-auto px-6">
    <SectionWithIcon icon={sectionIcon}>
      <Fragment slot="header">
        <p class="font-label text-xs uppercase tracking-widest text-primary mb-2">Typy stron</p>
        <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight">Typy stron (16)</h2>
      </Fragment>
    <!-- Mobile: accordions -->
    <div class="lg:hidden flex flex-col gap-3">
      {pageTypes.map((type, i) => (
        <details class="group bg-white" name="page-types">
          <summary class="flex justify-between items-center p-5 cursor-pointer list-none hover:bg-surface transition-colors">
            <div>
              <span class="font-headline font-bold text-lg text-foreground group-open:text-primary">{type.name}</span>
              <span class="ml-3 text-xs font-label text-muted">{type.badge}</span>
            </div>
            <span class="material-symbols-outlined text-muted group-open:text-primary transition-transform duration-300 group-open:rotate-180">keyboard_arrow_down</span>
          </summary>
          <div class="px-5 pb-5">
            <p class="text-muted text-sm leading-relaxed mb-6">{type.description}</p>
            <div class="flex flex-col gap-4">
              <div class="bg-surface-primary p-5 flex flex-col gap-4">
                <h4 class="font-headline text-lg font-bold tracking-tight">Archetypy</h4>
                <ul class="space-y-3">
                  {type.archetypes.map((a) => (
                    <li>
                      <span class="font-bold text-sm block mb-0.5">{a.name}</span>
                      <p class="text-xs text-muted leading-relaxed">{a.sub}</p>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="bg-surface-primary p-5 flex flex-col gap-4">
                <h4 class="font-headline text-lg font-bold tracking-tight">Wzorce sekcji</h4>
                <ul class="space-y-3">
                  {type.patterns.map((p) => (
                    <li>
                      <span class="font-bold text-sm block mb-0.5">{p.name}</span>
                      <p class="text-xs text-muted leading-relaxed">{p.sub}</p>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="bg-surface-primary p-5 flex flex-col gap-4">
                <h4 class="font-headline text-lg font-bold tracking-tight">Discovery</h4>
                <ul class="space-y-3">
                  {type.discovery.map((d) => (
                    <li>
                      <span class="font-bold text-sm block mb-0.5">{d.name}</span>
                      <p class="text-xs text-muted leading-relaxed">{d.sub}</p>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Desktop: two-column layout -->
    <div class="hidden lg:grid lg:grid-cols-12 gap-6 items-start">
      <!-- Left: nav -->
      <div class="lg:col-span-3">
        <nav class="flex flex-col gap-2" aria-label="Typy stron">
          {pageTypes.map((type, i) => (
          <button
            data-idx={i}
            class:list={[
              'kb-nav w-full flex items-center justify-between px-4 py-3 text-left transition-colors duration-150 cursor-pointer',
              i === 0
                ? 'bg-primary text-on-primary font-bold hover:bg-primary'
                : 'bg-white text-foreground hover:bg-surface',
            ]}
          >
            <span class="text-sm">{type.name}</span>
            <span class:list={["material-symbols-outlined text-base kb-chevron", i === 0 ? 'text-white' : 'text-muted']}>chevron_right</span>
          </button>
        ))}
        </nav>
      </div>

      <!-- Right: detail (header + cards) with white bg -->
      {pageTypes.map((type, i) => (
        <article
          data-detail={i}
          class:list={[
            'kb-detail lg:col-span-9 bg-white',
            i !== 0 && 'hidden',
          ]}
        >
          <div class="p-6 md:p-8 lg:p-10">
            <p class="font-label text-xs uppercase tracking-widest text-muted mb-3">Wybrany typ strony</p>
            <h3 class="font-headline text-2xl md:text-4xl font-bold uppercase tracking-tight mb-2">{type.name}</h3>
            <p class="text-muted text-base leading-relaxed max-w-2xl">{type.description}</p>
          </div>

          <div class="flex flex-col divide-y divide-border px-6 pb-6 md:px-8 md:pb-8 lg:px-10 lg:pb-10">
            <div class="py-6 flex flex-col gap-4">
              <div class="flex items-start justify-between">
                <span class="material-symbols-outlined text-primary text-2xl">category</span>
                <span class="font-label text-xs text-muted">01</span>
              </div>
              <h4 class="font-headline text-lg font-bold tracking-tight">Archetypy</h4>
              <ul class="space-y-3">
                {type.archetypes.map((a) => (
                  <li>
                    <span class="font-bold text-sm block mb-0.5">{a.name}</span>
                    <p class="text-xs text-muted leading-relaxed">{a.sub}</p>
                  </li>
                ))}
              </ul>
            </div>
            <div class="py-6 flex flex-col gap-4">
              <div class="flex items-start justify-between">
                <span class="material-symbols-outlined text-primary text-2xl">layers</span>
                <span class="font-label text-xs text-muted">02</span>
              </div>
              <h4 class="font-headline text-lg font-bold tracking-tight">Wzorce sekcji</h4>
              <ul class="space-y-3">
                {type.patterns.map((p) => (
                  <li>
                    <span class="font-bold text-sm block mb-0.5">{p.name}</span>
                    <p class="text-xs text-muted leading-relaxed">{p.sub}</p>
                  </li>
                ))}
              </ul>
            </div>
            <div class="py-6 flex flex-col gap-4">
              <div class="flex items-start justify-between">
                <span class="material-symbols-outlined text-primary text-2xl">search</span>
                <span class="font-label text-xs text-muted">03</span>
              </div>
              <h4 class="font-headline text-lg font-bold tracking-tight">Discovery</h4>
              <ul class="space-y-3">
                {type.discovery.map((d) => (
                  <li>
                    <span class="font-bold text-sm block mb-0.5">{d.name}</span>
                    <p class="text-xs text-muted leading-relaxed">{d.sub}</p>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
    </SectionWithIcon>
  </div>
</section>

<script>
  const navButtons = document.querySelectorAll<HTMLButtonElement>('.kb-nav');
  const details = document.querySelectorAll<HTMLElement>('.kb-detail');

  navButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = btn.dataset.idx;

      // Update nav
      navButtons.forEach((b) => {
        b.classList.remove('bg-primary', 'text-on-primary', 'font-bold', 'hover:bg-primary');
        b.classList.add('bg-white', 'text-foreground', 'hover:bg-surface');
        b.querySelector('.kb-chevron')?.classList.remove('text-white');
        b.querySelector('.kb-chevron')?.classList.add('text-muted');
      });
      btn.classList.remove('bg-white', 'text-foreground', 'hover:bg-surface');
      btn.classList.add('bg-primary', 'text-on-primary', 'font-bold', 'hover:bg-primary');
      btn.querySelector('.kb-chevron')?.classList.remove('text-muted');
      btn.querySelector('.kb-chevron')?.classList.add('text-white');

      // Update detail
      details.forEach((d) => {
        d.classList.toggle('hidden', d.dataset.detail !== idx);
      });
    });
  });
</script>
