---
import SectionWithIcon from '../../ui/SectionWithIcon.astro';
import sectionIcon from '../../../assets/icons/shape-4.svg';

const pageTypes = [
  {
    name: 'B2B SaaS',
    badge: 'Standard rynkowy',
    description: 'Optymalizacja pod kątem konwersji trial-to-paid i czytelności value proposition.',
    archetypes: [
      { name: 'Product-Led Growth', sub: 'Model skupiony na samodzielnym onboardingu użytkownika.' },
      { name: 'Enterprise Sales', sub: 'Leady kierowane do działu sprzedaży, wysoki stopień personalizacji.' },
      { name: 'Developer Tool', sub: 'Skupienie na dokumentacji i technicznym "utility value".' },
    ],
    patterns: [
      { name: 'Pricing Tiers (Complex)', sub: 'Porównywarka planów z matrycą funkcji.' },
      { name: 'Feature Deep-dive', sub: 'Interaktywne prezentacje kluczowych funkcjonalności.' },
      { name: 'Integration Cloud', sub: 'Ekosystem aplikacji współpracujących z produktem.' },
    ],
    discovery: [
      { name: 'User Jobs-to-be-done', sub: 'Identyfikacja celów jakie użytkownik chce osiągnąć.' },
      { name: 'Pain Point Mapping', sub: 'Analiza wąskich gardeł w obecnych procesach klienta.' },
      { name: 'Technical Stack Audit', sub: 'Weryfikacja kompatybilności technologicznej.' },
    ],
  },
  {
    name: 'B2B Services',
    badge: 'Usługi profesjonalne',
    description: 'Agencje, konsulting, software houses. Budowanie zaufania i generowanie leadów.',
    archetypes: [
      { name: 'Agency', sub: 'Prezentacja portfolio i procesu współpracy.' },
      { name: 'Consultancy', sub: 'Thought leadership i case studies jako proof of expertise.' },
      { name: 'Outsourcing', sub: 'Skala zespołu, certyfikaty, compliance.' },
    ],
    patterns: [
      { name: 'Case Study Grid', sub: 'Galeria projektów z metrykami sukcesu.' },
      { name: 'Process Timeline', sub: 'Wizualizacja etapów współpracy.' },
      { name: 'Team Showcase', sub: 'Prezentacja kompetencji zespołu.' },
    ],
    discovery: [
      { name: 'Service Differentiation', sub: 'Co wyróżnia na tle konkurencji.' },
      { name: 'Client Pain Points', sub: 'Problemy, które klient chce rozwiązać.' },
      { name: 'Competitor Positioning', sub: 'Mapa pozycjonowania rynkowego.' },
    ],
  },
  {
    name: 'B2B Industrial',
    badge: 'Przemysł',
    description: 'Producenci, dystrybutorzy. Katalogi produktowe i zapytania ofertowe.',
    archetypes: [
      { name: 'Manufacturer', sub: 'Katalog produktów technicznych z parametrami.' },
      { name: 'Distributor', sub: 'Wyszukiwarka asortymentu i dostępności.' },
      { name: 'OEM', sub: 'Strona partnerska z dokumentacją techniczną.' },
    ],
    patterns: [
      { name: 'Product Catalog', sub: 'Filtrowanie po parametrach technicznych.' },
      { name: 'RFQ Form', sub: 'Formularz zapytania ofertowego z konfiguratorem.' },
      { name: 'Technical Specs', sub: 'Karty techniczne do pobrania (PDF).' },
    ],
    discovery: [
      { name: 'Buyer Journey Mapping', sub: 'Ścieżka od researchu do zamówienia.' },
      { name: 'Technical Requirements', sub: 'Wymagania techniczne odbiorców.' },
      { name: 'Compliance Needs', sub: 'Normy i certyfikaty branżowe.' },
    ],
  },
  {
    name: 'E-commerce',
    badge: 'Sprzedaż online',
    description: 'Sklepy online, DTC. Optymalizacja ścieżki zakupowej i konwersji.',
    archetypes: [
      { name: 'DTC Brand', sub: 'Marka sprzedająca bezpośrednio do konsumenta.' },
      { name: 'Multi-brand Store', sub: 'Sklep z wieloma markami i kategoriami.' },
      { name: 'Subscription Box', sub: 'Model subskrypcyjny z cykliczną dostawą.' },
    ],
    patterns: [
      { name: 'Product Grid', sub: 'Siatka produktów z filtrami i sortowaniem.' },
      { name: 'Cart Optimization', sub: 'Koszyk z cross-sell i redukcją porzuceń.' },
      { name: 'Urgency Triggers', sub: 'Liczniki, ograniczona dostępność, social proof.' },
    ],
    discovery: [
      { name: 'Purchase Motivation', sub: 'Dlaczego klient kupuje ten produkt.' },
      { name: 'Abandonment Analysis', sub: 'Gdzie i dlaczego porzuca koszyk.' },
      { name: 'AOV Optimization', sub: 'Strategie zwiększania wartości zamówienia.' },
    ],
  },
  {
    name: 'Portfolio',
    badge: 'Kreatywni',
    description: 'Studia kreatywne, freelancerzy. Prezentacja prac i przyciąganie klientów.',
    archetypes: [
      { name: 'Design Studio', sub: 'Zespół z szerokim portfolio i procesem.' },
      { name: 'Freelancer', sub: 'Osobista marka z niszową specjalizacją.' },
      { name: 'Creative Agency', sub: 'Agencja kreatywna z kampaniami i case studies.' },
    ],
    patterns: [
      { name: 'Project Gallery', sub: 'Galeria prac z filtrowaniem po kategorii.' },
      { name: 'Client Testimonials', sub: 'Rekomendacje klientów z kontekstem projektu.' },
      { name: 'About/Story', sub: 'Narracja o podejściu i wartościach.' },
    ],
    discovery: [
      { name: 'Target Client Profile', sub: 'Kim jest idealny klient.' },
      { name: 'Unique Value Prop', sub: 'Co wyróżnia na tle innych studiów.' },
      { name: 'Work Showcase Strategy', sub: 'Jak najlepiej prezentować projekty.' },
    ],
  },
  {
    name: 'Local Business',
    badge: 'Lokalne usługi',
    description: 'Usługi lokalne. SEO lokalne, mapki, rezerwacje.',
    archetypes: [
      { name: 'Restaurant', sub: 'Menu, rezerwacje, lokalizacja.' },
      { name: 'Medical Practice', sub: 'Rejestracja online, specjalizacje, opinie.' },
      { name: 'Service Provider', sub: 'Hydraulik, elektryk — szybki kontakt i zasięg.' },
    ],
    patterns: [
      { name: 'Location Map', sub: 'Mapa z godzinami otwarcia i dojazdem.' },
      { name: 'Booking Widget', sub: 'Formularz rezerwacji z kalendarzem.' },
      { name: 'Reviews Carousel', sub: 'Opinie z Google/Facebook.' },
    ],
    discovery: [
      { name: 'Local Search Intent', sub: 'Frazy z lokalizacją ("dentysta Kraków").' },
      { name: 'Service Area Analysis', sub: 'Zasięg geograficzny usług.' },
      { name: 'Competitor Audit', sub: 'Porównanie z lokalnymi konkurentami.' },
    ],
  },
  {
    name: 'Marketplace',
    badge: 'Platformy',
    description: 'Platformy dwustronne. Balansowanie potrzeb sprzedawców i kupujących.',
    archetypes: [
      { name: 'B2C Marketplace', sub: 'Konsumenci kupują od wielu sprzedawców.' },
      { name: 'B2B Marketplace', sub: 'Hurtowe zamówienia między firmami.' },
      { name: 'Service Marketplace', sub: 'Łączenie usługodawców z klientami.' },
    ],
    patterns: [
      { name: 'Dual CTA Hero', sub: 'Osobne ścieżki dla kupujących i sprzedających.' },
      { name: 'Seller Onboarding', sub: 'Proces rejestracji i aktywacji sprzedawcy.' },
      { name: 'Trust & Safety', sub: 'Weryfikacja, oceny, gwarancje.' },
    ],
    discovery: [
      { name: 'Two-sided Value Prop', sub: 'Wartość dla obu stron rynku.' },
      { name: 'Network Effects', sub: 'Jak skala poprawia jakość platformy.' },
      { name: 'Chicken-and-Egg Problem', sub: 'Strategia startu bez masy krytycznej.' },
    ],
  },
  {
    name: 'Community',
    badge: 'Społeczności',
    description: 'Grupy, fora, platformy społecznościowe. Engagement i retencja.',
    archetypes: [
      { name: 'Professional Network', sub: 'Sieć branżowa z wymianą wiedzy.' },
      { name: 'Interest Group', sub: 'Społeczność wokół hobby lub tematu.' },
      { name: 'Learning Community', sub: 'Grupa ucząca się razem z mentorami.' },
    ],
    patterns: [
      { name: 'Activity Feed', sub: 'Strumień aktywności i dyskusji.' },
      { name: 'Member Profiles', sub: 'Profile z osiągnięciami i rolami.' },
      { name: 'Event Calendar', sub: 'Nadchodzące spotkania i webinary.' },
    ],
    discovery: [
      { name: 'Community Purpose', sub: 'Dlaczego ludzie dołączają i zostają.' },
      { name: 'Engagement Loops', sub: 'Mechanizmy powracania i aktywności.' },
      { name: 'Moderation Strategy', sub: 'Zasady i narzędzia moderacji.' },
    ],
  },
  {
    name: 'Course',
    badge: 'Edukacja',
    description: 'Kursy, szkolenia online. Konwersja na zapisy i prezentacja programu.',
    archetypes: [
      { name: 'Self-paced Course', sub: 'Kurs do przerobienia w swoim tempie.' },
      { name: 'Cohort-based', sub: 'Grupy startujące w tym samym terminie.' },
      { name: 'Workshop', sub: 'Intensywne warsztaty z praktyką.' },
    ],
    patterns: [
      { name: 'Curriculum Breakdown', sub: 'Rozkład modułów i lekcji.' },
      { name: 'Instructor Bio', sub: 'Ekspertyza i doświadczenie prowadzącego.' },
      { name: 'Student Results', sub: 'Metryki sukcesu absolwentów.' },
    ],
    discovery: [
      { name: 'Learning Outcomes', sub: 'Co uczestnik będzie potrafił po kursie.' },
      { name: 'Student Persona', sub: 'Poziom zaawansowania i cele.' },
      { name: 'Pricing Psychology', sub: 'Postrzeganie wartości vs. cena.' },
    ],
