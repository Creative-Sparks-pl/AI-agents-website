      { name: 'Calculator', sub: 'Kalkulator z wynikiem w czasie rzeczywistym.' },
      { name: 'Generator', sub: 'Generator treści, kodu lub grafiki.' },
    ],
    patterns: [
      { name: 'Tool-first Hero', sub: 'Narzędzie widoczne od razu na hero.' },
      { name: 'How-it-works', sub: 'Trzy kroki do rezultatu.' },
      { name: 'Use Case Gallery', sub: 'Przykłady zastosowań narzędzia.' },
    ],
    discovery: [
