  },
  {
    name: 'Government',
    badge: 'Sektor publiczny',
    description: 'Instytucje publiczne. Dostępność, WCAG, przejrzystość.',
    archetypes: [
      { name: 'Municipal Website', sub: 'Strona gminy/miasta z e-usługami.' },
      { name: 'Public Service', sub: 'Portal usługowy instytucji publicznej.' },
      { name: 'Regulatory Body', sub: 'Organ regulacyjny z dokumentacją.' },
    ],
    patterns: [
      { name: 'Service Finder', sub: 'Wyszukiwarka usług publicznych.' },
      { name: 'Document Library', sub: 'Biblioteka dokumentów do pobrania.' },
      { name: 'Accessibility Features', sub: 'Powiększanie tekstu, kontrast, czytnik.' },
    ],
    discovery: [
      { name: 'Citizen Needs', sub: 'Jakie sprawy obywatele załatwiają online.' },
      { name: 'Compliance Requirements', sub: 'WCAG, RODO, ustawa o dostępności.' },
      { name: 'Digital Inclusion', sub: 'Dostęp dla seniorów i osób wykluczonych.' },
    ],
  },
  {
    name: 'Documentation',
    badge: 'Docs & Help',
