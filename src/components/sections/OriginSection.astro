---
import type { HTMLAttributes } from 'astro/types';
import SectionWithIcon from '../ui/SectionWithIcon.astro';
import sectionIcon from '../../assets/icons/shape-7.svg';

interface Props extends HTMLAttributes<'section'> {
  class?: string;
}

const {
  class: className,
  ...rest
} = Astro.props;

const comparisons = [
  { label: 'Chatbot', description: 'Tylko odpowiada na pytania. Nie prowadzi projektu krok po kroku.' },
  { label: 'Kolekcje promptów', description: 'Dają fragmenty, ale brakuje spójnej metodologii i pamięci projektu.' },
  { label: 'Szablony UI', description: 'Ładnie wyglądają, ale nie mają strategii. Wygląd bez procesu.' },
];
---

<section
  class:list={['py-20 md:py-28 bg-surface', className]}
  aria-labelledby="origin-heading"
  {...rest}
>
  <div class="max-w-screen-2xl mx-auto px-6">
    <SectionWithIcon icon={sectionIcon}>
      <Fragment slot="header">
        <span class="text-sm font-label text-primary mb-4">Dlaczego powstał</span>
        <h2 id="origin-heading" class="font-headline text-4xl md:text-5xl font-bold text-foreground leading-[1.1] tracking-tight">
          Zbudowałem agenta,<br />którego sam chciałem mieć.
        </h2>
      </Fragment>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 items-start">
        <!-- Left: comparison grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {comparisons.map((item) => (
            <div class="p-8 bg-white">
              <h3 class="text-xs font-label font-bold text-muted mb-3">{item.label}</h3>
              <p class="text-base font-body leading-relaxed text-muted">{item.description}</p>
            </div>
          ))}
          <div class="p-8 bg-surface-primary">
            <h3 class="text-xs font-label font-bold text-primary mb-3">UX Design Agent</h3>
            <p class="text-base font-body leading-relaxed text-foreground font-bold">
              Prowadzi cały proces. Strategia, persony i wireframe z realnym copy.
            </p>
          </div>
        </div>

        <!-- Right: text + callout -->
        <div>
          <p class="text-lg text-muted leading-relaxed mb-12 font-body font-medium">
            Designerowi oszczędza godziny. Marketerowi i devowi daje coś, co wcześniej wymagało budżetu na konsultanta.
          </p>
          <div class="p-8 bg-surface-primary inline-flex items-center gap-6">
            <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-white" data-icon="robot_2" aria-hidden="true">robot_2</span>
            </div>
            <span class="font-headline font-bold tracking-tight text-foreground">Jeden agent, pełen cykl, realne pliki.</span>
          </div>
        </div>
      </div>
    </SectionWithIcon>
  </div>
</section>
